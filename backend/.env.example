# Copie este arquivo para ".env" apenas no ambiente local.
# Em produção, configure as variáveis diretamente no painel da hospedagem.

APP_ENV=development
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
JWT_SECRET=troque-por-uma-string-aleatoria-longa-com-mais-de-32-caracteres
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
ENABLE_PUBLIC_TECH_REGISTRATION=false
ALLOW_DEV_RESET_TOKEN=true
SEED_DEMO=true
MAX_UPLOAD_BYTES=5242880

# Opcional: PostgreSQL em produção. Sem isso, usa SQLite local.
# DATABASE_URL=postgresql://usuario:senha@host:5432/banco

# Opcional: envio real de e-mail.
# SMTP_HOST=smtp.exemplo.com
# SMTP_PORT=587
# SMTP_USER=no-reply@exemplo.com
# SMTP_PASS=sua-senha
# SMTP_FROM=no-reply@exemplo.com
